{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing personal information and roles.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "cpf": { "type": "string" },
        "neighborhood": { "type": "string" },
        "role": { "type": "string", "enum": ["citizen", "admin", "mayor", "secretary", "coordinator", "triage", "field"] },
        "departmentId": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp in milliseconds" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Department": {
      "title": "Department",
      "description": "City department handling tickets.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "acronym": { "type": "string" },
        "active": { "type": "boolean" },
        "color": { "type": "string" }
      },
      "required": ["name", "acronym", "active"]
    },
    "Category": {
      "title": "Category",
      "description": "Ticket category (e.g. Pothole, Trash).",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "iconName": { "type": "string" },
        "color": { "type": "string" },
        "defaultDepartmentId": { "type": "string" },
        "defaultPriority": { "type": "string" }
      },
      "required": ["name", "iconName", "color", "defaultDepartmentId", "defaultPriority"]
    },
    "Ticket": {
      "title": "Ticket",
      "description": "A citizen request or complaint.",
      "type": "object",
      "properties": {
        "protocol": { "type": "string" },
        "userId": { "type": "string" },
        "categoryId": { "type": "string" },
        "departmentId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["received", "triage", "forwarded", "analyzing", "scheduled", "in_progress", "resolved", "closed", "duplicated", "rejected", "waiting_info"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "address": { "type": "string" },
        "neighborhood": { "type": "string" },
        "photoUrl": { "type": "string" },
        "resolvedPhotoUrl": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["protocol", "userId", "categoryId", "departmentId", "title", "description", "status", "priority", "address", "createdAt"]
    },
    "TicketHistory": {
      "title": "TicketHistory",
      "description": "History of actions on a ticket.",
      "type": "object",
      "properties": {
        "ticketId": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "oldStatus": { "type": "string" },
        "newStatus": { "type": "string" },
        "comment": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["ticketId", "userId", "action", "createdAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Top-level collection for users"
    },
    "departments": {
      "schema": { "$ref": "#/entities/Department" },
      "description": "Top-level collection for departments"
    },
    "categories": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Top-level collection for categories"
    },
    "tickets": {
      "schema": { "$ref": "#/entities/Ticket" },
      "description": "Top-level collection for tickets"
    },
    "ticketHistory": {
      "schema": { "$ref": "#/entities/TicketHistory" },
      "description": "Top-level collection for ticket histories"
    }
  }
}
